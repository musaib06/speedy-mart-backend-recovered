{
  "ApplicationIdentification": {
    "ApplicationName": "Siffrum.Ecom.API",
    "AppNameToken": ""
  },
  "APIConfiguration": {
    "IsSwaggerEnabled": true,
    "IsCorsEnabled": true,
    "IsOdataEnabled": true,
    "EnableFullRequestResponseLog": false,
    "EnableLogForNoLog": false,
    "FileExceptionLogPath": "ExceptionInFile.txt",
    "ApiDbConnectionString": "Host=DB_HOST;Port=5432;Database=DB_NAME;Username=DB_USER;Password=DB_PASSWORD;",
    "JwtIssuerName": "www.siffrum.com",
    "JwtTokenSigningKey": "CHANGE_ME_32_CHAR_KEY_HERE______",
    "AuthTokenEncryptionKey": "CHANGE_ME_32_CHAR_KEY_HERE______",
    "AuthTokenDecryptionKey": "CHANGE_ME_32_CHAR_KEY_HERE______",
    "DefaultTokenValidityDays": 30,
    "SuperAdminSettings": {
      "Username": "SUPER_ADMIN_USERNAME",
      "Email": "SUPER_ADMIN_EMAIL",
      "Password": "SUPER_ADMIN_PASSWORD"
    }
  },
  "AppleAuth": {
    "ClientId": "com.siffrum.ecom.web",
    "TeamId": "APPLE_TEAM_ID",
    "KeyId": "APPLE_KEY_ID",
    "PrivateKeyPath": "Keys/AuthKey.p8"
  },
  "RazorpaySettings": {
    "KeyId": "RAZORPAY_KEY_ID",
    "KeySecret": "RAZORPAY_KEY_SECRET",
    "WebhookSecret": "RAZORPAY_WEBHOOK_SECRET",
    "Signature": "RAZORPAY_SIGNATURE"
  },
  "GoogleCloudLocation": {
    "ApiKey": "GOOGLE_MAPS_API_KEY"
  },
  "OneSignalSettings": {
    "BaseUrl": "https://onesignal.com/api/v1/notifications",
    "AppId": "ONESIGNAL_APP_ID",
    "RestApiKey": "ONESIGNAL_REST_API_KEY"
  },
  "SmsSettings": {
    "BaseUrl": "https://myinboxmedia.in/api/sms",
    "UserId": "SMS_USER_ID",
    "Password": "SMS_PASSWORD",
    "Sender": "SPDKRT",
    "MsgType": 13,
    "PeId": "SMS_PE_ID",
    "TemplateId": "SMS_TEMPLATE_ID"
  },
  "SmtpMailSettings": {
    "UserId": "SMTP_EMAIL",
    "Password": "SMTP_APP_PASSWORD",
    "Port": 587,
    "Host": "smtp.gmail.com",
    "EnableSSL": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
